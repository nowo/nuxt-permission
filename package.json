{
    "name": "nuxt-permission",
    "type": "module",
    "version": "2.0.0",
    "packageManager": "pnpm@10.34.4",
    "description": "Backend menu / permission driven dynamic routes and permissions for Nuxt: non-whitelisted routes register after login, with built-in permission state and hasPermission.",
    "license": "MIT",
    "homepage": "https://github.com/nowo/nuxt-permission#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nowo/nuxt-permission.git"
    },
    "bugs": "https://github.com/nowo/nuxt-permission/issues",
    "keywords": [
        "nuxt",
        "nuxt-module",
        "permission",
        "rbac",
        "dynamic-routes",
        "menu",
        "vue-router"
    ],
    "exports": {
        ".": {
            "types": "./dist/types.d.mts",
            "import": "./dist/module.mjs"
        }
    },
    "main": "./dist/module.mjs",
    "typesVersions": {
        "*": {
            ".": [
                "./dist/types.d.mts"
            ]
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "prepack": "nuxt-module-build build",
        "dev": "npm run dev:prepare && nuxt dev playground",
        "dev:docs": "pnpm --filter nuxt-permission-docs dev",
        "dev:build": "nuxt build playground",
        "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
    },
    "dependencies": {
        "@nuxt/kit": "^4.4.8"
    },
    "devDependencies": {
        "@nuxt/devtools": "^3.2.4",
        "@nuxt/module-builder": "^1.0.2",
        "@nuxt/schema": "^4.4.8",
        "@nuxt/test-utils": "^4.0.3",
        "@types/node": "latest",
        "@wzo/eslint-config": "^0.0.3",
        "eslint": "^10.4.1",
        "nuxt": "^4.4.8",
        "typescript": "~6.0.3",
        "vitest": "^4.1.8",
        "vue-tsc": "^3.3.3"
    }
}

{
    "compilerOptions": {
        "target": "ESNext",
        "jsx": "preserve",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "types": ["vite/client"],
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["src", "src/**/*.vue", "vite.config.ts"]
}
